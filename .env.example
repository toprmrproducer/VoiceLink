# --- api ---
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

MONGO_URL=mongodb://localhost:27018/voiceplatform
REDIS_URL=redis://localhost:6380

JWT_SECRET=replace-with-32-byte-random
JWT_EXPIRES_IN=7d

# AES-256-GCM key for encrypting BYOK secrets at rest. 32 bytes hex = 64 chars.
# Generate with: openssl rand -hex 32
BYOK_ENCRYPTION_KEY=replace-with-64-hex-chars

VOICELINK_API_BASE=https://app.voicelink.co.in/api
VOICELINK_MODE=live
# HOW TO GET THE TOKEN: it is a VoiceLink account Bearer token (format "1234|hash").
# Either paste one here, OR leave it blank and set username+password below — the app
# mints it for you via POST https://app.voicelink.co.in/api/v1/auth/login (returns
# data.access_token). You need a VoiceLink account with a DID and at least 1 channel.
VOICELINK_RESELLER_TOKEN=
# Optional: set these instead of the token and the app logs in + auto-refreshes it.
VOICELINK_RESELLER_USERNAME=
VOICELINK_RESELLER_PASSWORD=
# Leave empty (VoiceLink does not sign webhooks; a value here makes the app reject them).
VOICELINK_WEBHOOK_SECRET=

OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=
PLAYHT_USER_ID=
PLAYHT_API_KEY=

DOGRAH_MCP_URL=https://app.dograh.com/api/v1/mcp/
DOGRAH_MCP_KEY=

S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# --- ui (public) ---
NEXT_PUBLIC_API_BASE=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-byte-random
